{
  "name": "@trainframe/simulator-ui",
  "private": true,
  "version": "0.1.0",
  "description": "Browser simulator UI. Runs a Trainframe simulation in the browser and publishes events to an MQTT broker.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.33.0",
    "@trainframe/protocol": "workspace:*",
    "@trainframe/simulator": "workspace:*",
    "@trainframe/ui-kit": "workspace:*",
    "mqtt": "^5.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "aedes": "^1.0.2",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.0"
  }
}
