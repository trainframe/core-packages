{
  "name": "@trainframe/simulator",
  "version": "0.1.0",
  "description": "The Trainframe physics simulator (ADR-030): the real device world for tests, demos, and the toy table.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "files": ["src"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.33.0",
    "@trainframe/core": "workspace:*",
    "@trainframe/protocol": "workspace:*",
    "@trainframe/server": "workspace:*",
    "mqtt": "^5.10.0"
  },
  "devDependencies": {
    "aedes": "^1.0.2",
    "vitest": "^2.1.0",
    "typescript": "^5.6.0"
  }
}
