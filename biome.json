{
  "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "ignore": [
      "**/dist/**",
      "**/node_modules/**",
      "**/*.generated.ts",
      "**/test-results/**",
      "**/playwright-report/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": { "maxAllowedComplexity": 15 }
        }
      },
      "correctness": {
        "noUnusedVariables": "error",
        "useExhaustiveDependencies": "error"
      },
      "style": {
        "useImportType": "error",
        "noNonNullAssertion": "warn"
      },
      "suspicious": {
        "noExplicitAny": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "overrides": [
    {
      "include": ["packages/simulator-ui/**"],
      "linter": {
        "rules": {
          "nursery": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "@trainframe/visualiser": "simulator-ui must not import from visualiser — see ADR-013 and packages/ui-kit for the shared primitives surface."
                }
              }
            }
          }
        }
      }
    },
    {
      "include": ["packages/visualiser/**"],
      "linter": {
        "rules": {
          "nursery": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "@trainframe/simulator-ui": "visualiser must not import from simulator-ui — see ADR-013 and packages/ui-kit for the shared primitives surface."
                }
              }
            }
          }
        }
      }
    },
    {
      "include": ["packages/ui-kit/**"],
      "linter": {
        "rules": {
          "nursery": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "@trainframe/simulator-ui": "ui-kit must not depend on either app — it is the shared primitive layer; see ADR-013.",
                  "@trainframe/visualiser": "ui-kit must not depend on either app — it is the shared primitive layer; see ADR-013."
                }
              }
            }
          }
        }
      }
    }
  ]
}
