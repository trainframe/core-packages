{
  "name": "trainframe",
  "private": true,
  "version": "0.1.0",
  "description": "A capability-based protocol for distributed model railways.",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:integration": "pnpm --filter @trainframe/simulator test:integration",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "services": "podman compose -f tools/broker/docker-compose.yml up",
    "services:build": "podman compose -f tools/broker/docker-compose.yml build",
    "services:down": "podman compose -f tools/broker/docker-compose.yml down",
    "server:dev": "node packages/server/dist/cli.js --discovery --broker mqtt://localhost:1883 --http-port 0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@vitest/coverage-v8": "2.1.9",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
